# ─────────────────────────────────────────────────────────
# WP Dash — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME=WP Dash
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_DESCRIPTION=Centralized WordPress monitoring and maintenance dashboard

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/wpdash

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Uptime checks
UPTIME_CHECK_TIMEOUT_MS=15000
UPTIME_RETENTION_DAYS=7

# Backup
BACKUP_STALE_THRESHOLD_DAYS=7

# WP Bridge
WP_BRIDGE_TIMEOUT_MS=15000
WP_BRIDGE_MAX_RETRIES=2
WP_BRIDGE_RETRY_DELAY_MS=1000

# Rate limiting
API_RATE_LIMIT_PER_MINUTE=60

# Stripe (optional — for commercial plan billing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_PRICE_ID=price_your_pro_price_id
STRIPE_AGENCY_PRICE_ID=price_your_agency_price_id
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# Resend (optional — for email alerts)
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=alerts@wpdash.app

